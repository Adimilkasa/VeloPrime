# Public site URL used for sitemap/metadata routes in production.
# Example:
# NEXT_PUBLIC_SITE_URL=https://veloradrive.pl
NEXT_PUBLIC_SITE_URL=

# Google Sheets inventory sync (server-side / local scripts)
# 1) Create a Google Cloud project + enable Google Sheets API
# 2) Create a Service Account and download JSON
# 3) Put JSON here (ignored by git): .secrets/google-service-account.json
# 4) Share the Google Sheet with the service account email (Viewer)
# On Vercel prefer GOOGLE_SERVICE_ACCOUNT_JSON instead of a file path.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=.secrets/google-service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Inventory
# Optional: defaults to A1:Z
GOOGLE_SHEETS_RANGE=A1:Z

# Partner signups automation
GOOGLE_PARTNER_SIGNUPS_SHEET_ID=
GOOGLE_PARTNER_SIGNUPS_PENDING_SHEET_TAB=Bez platnosci
GOOGLE_PARTNER_SIGNUPS_PAID_SHEET_TAB=Partnerzy

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
PARTNER_WELCOME_REPLY_TO=
PARTNER_SIGNUP_ADMIN_EMAIL=

DISCORD_PARTNER_SIGNUPS_WEBHOOK_URL=

# Cooperation landing automation
GOOGLE_COOPERATION_SHEET_ID=
# Optional: defaults to "Wspolpraca"
GOOGLE_COOPERATION_SHEET_TAB=Wspolpraca
DISCORD_COOPERATION_WEBHOOK_URL=

# Offer/contact leads automation
GOOGLE_OFFER_SHEET_ID=
# Optional: defaults to "Oferta"
GOOGLE_OFFER_SHEET_TAB=Oferta
DISCORD_OFFER_WEBHOOK_URL=

# Webinar automation
GOOGLE_WEBINAR_SHEET_ID=
# Optional: defaults to "Webinar"
GOOGLE_WEBINAR_SHEET_TAB=Webinar

# Webinar meeting links (one per slot)
WEBINAR_LINK_TUESDAY_2000=
WEBINAR_LINK_THURSDAY_2000=
WEBINAR_LINK_SATURDAY_1100=

# Optional slot capacities (defaults to 50)
WEBINAR_SLOT_TUESDAY_2000_CAPACITY=50
WEBINAR_SLOT_THURSDAY_2000_CAPACITY=50
WEBINAR_SLOT_SATURDAY_1100_CAPACITY=50

# Optional fixed date for a one-time webinar slot (ISO format)
# Example: 2026-03-19T20:00:00+01:00
WEBINAR_SLOT_THURSDAY_2000_FIXED_DATE=

# Optional reply-to headers for outgoing emails
WEBINAR_CONFIRMATION_REPLY_TO=
WEBINAR_REMINDER_REPLY_TO=

# Authorization for /api/webinar-lead/reminders
WEBINAR_CRON_SECRET=

